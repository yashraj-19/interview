# ─────────────────────────────────────────────────────────────────────────────
# SViam Voice Interviewer — environment configuration
#
# 1. Copy this file to ".env"           (Windows: copy .env.example .env)
# 2. Fill in the two REQUIRED keys below (Deepgram + Groq — both have free tiers)
# 3. Everything else has sane defaults; leave it unless you know you need it.
#
# NEVER commit the real .env — it holds secrets and is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Deepgram — speech-to-text (nova-3) AND text-to-speech (Aura-2). ONE key, both.
# Free key + credit: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key_here

# Groq — runs BOTH the interviewer LLM and the separate judge LLM. Fast enough
# for live voice on the free tier. Free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# ── CONVERSATION LLM (the interviewer brain — defaults are good) ─────────────

# Provider: "groq" (default, recommended) or "gemini".
CONV_LLM_PROVIDER=groq
# Groq model. llama-4-scout follows the "never reveal the answer" rule well and
# fits the free tier. Swap to llama-3.3-70b-versatile on a paid tier if desired.
GROQ_CONV_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── JUDGE LLM (separate wrong-answer corrector — defaults are good) ──────────

JUDGE_PROVIDER=groq
JUDGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── OPTIONAL (commented out — uncomment only if you switch a provider) ───────

# Only if CONV_LLM_PROVIDER=gemini. Note: Gemini's free tier (5 req/min) is too
# slow for live voice — enable only with billing on. https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here

# Only if JUDGE_PROVIDER=anthropic (also run: pip install anthropic).
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Candidate-silence prompts: seconds before nudge / reprompt / move-on.
# Spec default is 30,90,120. Use 12,30,50 for quick local testing.
# SILENCE_SECS=30,90,120
